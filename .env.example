# ============================================================
#  Aivro 环境配置
#  使用方法：复制此文件为 .env，按需修改后启动。
#    cp .env.example .env
#    docker compose up -d
# ============================================================

# -------------------- 管理员账号 --------------------
# 首次启动时自动创建；密码至少 8 位并同时包含字母和数字。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-123

# -------------------- JWT 认证 --------------------
# 正式部署务必修改 JWT_SECRET，泄露会导致账号被伪造。
JWT_SECRET=change-me-random-32-bytes
JWT_EXPIRE_HOURS=168

# 站点可信外部访问地址，用于生成 OAuth 回调、支付回跳、KYC 回调和分享链接。
# 正式部署务必填写实际 HTTPS 域名（不要保留 localhost），例如：https://aivro.org
# 谷歌/GitHub 登录的回调地址即由此生成：{APP_ORIGIN}/api/auth/oauth/<provider>/callback
# 例如谷歌登录需在 Google Cloud Console 的“已授权的重定向 URI”中登记：
#   https://aivro.org/api/auth/oauth/google/callback
# 若此处与 Google Console 登记值不一致，会出现 redirect_uri_mismatch（错误 400）。
APP_ORIGIN=http://localhost:3000

# 可选：允许从请求 Host 推断来源的域名列表，多个用英文逗号分隔。
# 已配置 APP_ORIGIN 时优先使用 APP_ORIGIN。
# ALLOWED_ORIGINS=http://localhost:3000,https://aivro.example.com

# -------------------- 服务端口 --------------------
# 容器内部 Go 后端监听端口，一般无需修改。
PORT=8080

# 前端开发时如果后端端口不是 8080，可取消注释并修改。
# API_BASE_URL=http://127.0.0.1:8080

# ============================================================
#  数据库配置
#  支持三种驱动：postgres / sqlite / mysql
#  默认使用 PostgreSQL（配合 docker-compose 内置数据库容器）。
#  如需切换到 SQLite，请按下方说明注释/取消注释对应行。
# ============================================================

# ---------- PostgreSQL（推荐，适合多人/生产环境） ----------
# Docker Compose 已内置 PostgreSQL 容器，以下连接地址无需修改。
# 如使用外部 PostgreSQL，将 DATABASE_DSN 改为实际地址即可。
STORAGE_DRIVER=postgres
DATABASE_DSN=postgres://aivro:aivro@db:5432/aivro?sslmode=disable

# PostgreSQL 容器的账号密码和数据库名。
# 会同时用于 docker-compose 中的 db 容器初始化和应用连接。
POSTGRES_USER=aivro
POSTGRES_PASSWORD=aivro
POSTGRES_DB=aivro

# ---------- SQLite（适合本地单人使用，零配置） ----------
# 切换方法：
#   1. 注释掉上面 PostgreSQL 的三行（STORAGE_DRIVER / DATABASE_DSN / POSTGRES_*）。
#   2. 取消注释下面两行。
#   3. docker-compose.yml 中注释掉 db 和 depends_on 段落，或改用 docker-compose.local.yml。
# STORAGE_DRIVER=sqlite
# DATABASE_DSN=data/aivro.db

# ---------- MySQL（可选） ----------
# STORAGE_DRIVER=mysql
# DATABASE_DSN=user:password@tcp(127.0.0.1:3306)/aivro?parseTime=true

# ============================================================
#  Redis 缓存配置（第二阶段预留，需 PostgreSQL/MySQL）
#  第一版队列使用数据库实现，Redis 为后续高并发优化预留。
#  注意：Redis 队列后端仅支持 PostgreSQL/MySQL，不支持 SQLite。
# ============================================================

# ---------- Redis 配置 ----------
# 取消注释以启用 Redis（需在管理后台将队列后端改为 redis）
# REDIS_URL=redis://redis:6379/0
# REDIS_PASSWORD=
# REDIS_DB=0

# ============================================================
#  Redis 缓存配置（第二阶段预留，需 PostgreSQL/MySQL）
#  第一版队列使用数据库实现，Redis 为后续高并发优化预留。
#  注意：Redis 队列后端仅支持 PostgreSQL/MySQL，不支持 SQLite。
# ============================================================

# ---------- Redis 配置 ----------
# 取消注释以启用 Redis（需在管理后台将队列后端改为 redis）
# REDIS_URL=redis://redis:6379/0
# REDIS_PASSWORD=
# REDIS_DB=0
